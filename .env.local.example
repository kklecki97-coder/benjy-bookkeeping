# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Claude (Anthropic)
ANTHROPIC_API_KEY=

# QuickBooks Online (sandbox first)
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=
QBO_ENVIRONMENT=sandbox

# Shopify Admin API (Dev Dashboard app — client credentials grant)
SHOPIFY_STORE_DOMAIN=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Google Drive (auto-pull source files) — uses a SERVICE ACCOUNT, not OAuth.
# Value: base64 of the service-account JSON key file.
#   macOS/Linux: base64 -i service-account.json | tr -d '\n'
# Then share the Drive month folder (read-only) with the key's client_email.
GOOGLE_SERVICE_ACCOUNT_KEY_B64=

# Resend (email)
RESEND_API_KEY=

# Encryption key for QuickBooks tokens at rest — 32 bytes as 64 hex chars.
#   generate: openssl rand -hex 32
ENCRYPTION_KEY=
